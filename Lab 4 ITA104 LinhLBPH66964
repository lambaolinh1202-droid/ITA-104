DROP TABLE IF EXISTS SanPham;
CREATE TABLE SanPham (
    MaSP VARCHAR(10) PRIMARY KEY,
    TenSP VARCHAR(100) NOT NULL,
    DonGiaHienTai DECIMAL(18, 2) CHECK (DonGiaHienTai >= 0)
);
INSERT INTO SanPham (MaSP, TenSP, DonGiaHienTai) VALUES 
('SP01', 'Sữa tươi Vinamilk', 7000),
